# ── Frontend environment variables (Vite) ──
# Copy to `.env` for local dev, and set the same keys in your host (Netlify) dashboard.

# Base URL of the backend API. This is ALSO used for the Socket.IO connection.
# Local:  http://localhost:4000
# Prod:   https://your-backend.onrender.com
VITE_BASE_URL=http://localhost:4000

# Google Maps API key for CLIENT-side maps (Maps JavaScript + Places).
# This key ships in the built JS, so restrict it by HTTP referrer in Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key
